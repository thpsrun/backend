COMMUNITY_NAME="<COMMUNITY_NAME>"
POSTGRES_DB="<POSTGRES_TABLE>"
POSTGRES_USER="<POSTGRES_USER>"
POSTGRES_PASSWORD="<POSTGRES_PASSWORD>"
REDIS_PASSWORD="<REDIS_PASSWORD>"
SECRET_KEY="<SECRETKEY>" # https://djecrety.ir
SSL_HOST="<WEBSITE_URL>"
DEBUG_MODE="True" # MAKE SURE THIS IS SET TO FALSE IN PRODUCTION!!
ALLOWED_HOSTS=<IP>,localhost,django

# Comma-separated IPs or CIDR ranges of reverse proxies whose X-Forwarded-For header
# should be trusted (rate limiting, audit logging). Set this to the NPM (or other proxy)
# container/host IP when DEBUG_MODE is False; leave empty when Django is reached directly.
TRUSTED_PROXIES=

# Used for the db_backup.sh script. Instructions in README.
# HETZNER_ENDPOINT is the Hetzner Object Storage S3 endpoint for the bucket's location
HETZNER_BUCKET=<BUCKET NAME>
HETZNER_KEY=<ACCESS KEY ID>
HETZNER_SECRET=<SECRET ACCESS KEY>
HETZNER_ENDPOINT=https://hel1.your-objectstorage.com
HETZNER_REGION=hel1

# Generate a keypair on a secure machine: age-keygen -o identity.txt
# Put the PUBLIC key (age1...) below; keep identity.txt OFFLINE, never on this host.
AGE_RECIPIENT=age1...

# Sentry.io/Bugsink/GlitchTip sentry setup for consolidating logs
SENTRY_ENABLED="False"
SENTRY_DSN="<SENTRY_LINK>"

# Metadata for the website
SITE_NAME="<WEBSITE NAME>"
SITE_KEYWORDS=KEYWORDS,SEPARATED,BY,COMMAS
SITE_AUTHOR=<AUTHOR>
SITE_DESCRIPTION=<DESCRIPTION>

# If you do not want to use one of these on the website;leave it equal to ""
DISCORD_URL="<DISCORD>"
TWITTER_URL="https://twitter.com/<TWITTER>"
TWITCH_URL="https://twitch.tv/<TWITCH>"
YOUTUBE_URL="https://www.youtube.com/<YOUTUBE>"
SRC_URL="https://speedrun.com/<SERIESNAME>"
BLUESKY_URL="https://bsky.app/profile/<HANDLE>"

# Auth / Email (django-allauth + django-anymail)
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=your_resend_api_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile)
# In production, both must be set; the deploy workflow's environment must include them.
# In DEBUG, leave blank to fall back to Cloudflare's always-pass dummy keys
# (site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA), or
# override here with 2x... (always fail) / 3x... (token-already-spent) to test rejection
# paths on localhost.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Set to "True" only in local dev to bypass PathRateLimitMiddleware (3/hour caps on
# password reset, email change, resend, correct-email). Never set in production.
RATE_LIMIT_DISABLED=False

# SRC API Key Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SRC_ENCRYPTION_KEY=

SRC_V2_ENABLED="False" # Leave as false until you are ready for this to start
SRC_BOT_USERNAME="<BOTNAME>"
SRC_BOT_PASSWORD="<BOTPASS>"
SRC_BOT_MAILBOX_USER="<BOTMAIL>"
SRC_BOT_MAILBOX_APP_PASSWORD="<BOTMAILPASS>"
# Tune these only if SRC's email format differs from the defaults:
SRC_2FA_SENDER_EMAIL="noreply@speedrun.com"
SRC_2FA_SUBJECT_PATTERN="Speedrun login code"